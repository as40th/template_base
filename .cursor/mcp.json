{
  "mcpServers": {
    "context7-stdin": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    },
    "context7-http": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    }
  }
}